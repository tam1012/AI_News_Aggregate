# Database
DB_PASSWORD=thay-bang-mat-khau-manh

# Admin
ADMIN_TOKEN=thay-bang-chuoi-ngau-nhien-dai

# Public URL (used for Open Graph meta tags and share links)
PUBLIC_SITE_URL=https://your-domain.example.com

# Scraper
SCRAPE_INTERVAL_HOURS=1
MAX_ARTICLES_PER_SOURCE=20
MAX_AI_CALLS_PER_RUN=30
DIGEST_ARTICLE_LIMIT=100
VOZ_MAX_THREAD_PAGES=4
FORUM_MAX_COMMENTS=40
FORUM_RAW_CONTENT_MAX_LENGTH=60000
REDDIT_COMMENT_LIMIT=30
REDDIT_COMMENT_DEPTH=3

# Reddit OAuth (optional - enables full comment access)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Reddit Proxy (optional - Cloudflare Worker URL for bypassing IP block)
# Deploy reddit-proxy-worker.js to Cloudflare Workers, then set the URL here
REDDIT_PROXY_URL=

# VOZ host proxy (optional - Docker app to host GUI Chromium proxy)
# VOZ_PROXY_URL=http://host.docker.internal:8788/fetch
VOZ_PROXY_URL=


# CORS (set to your public domain)
CORS_ORIGIN=https://your-domain.example.com
