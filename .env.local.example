NODE_ENV=production
TZ=Asia/Ho_Chi_Minh
PORT=3000
PUBLIC_SITE_URL=https://synthnews.local
CORS_ORIGIN=https://synthnews.local

DATABASE_URL=postgresql://newstamhv:newstamhv_secret@127.0.0.1:5433/newstamhv
ADMIN_TOKEN=change-me-local-admin-token

SCRAPE_INTERVAL_HOURS=1
MAX_ARTICLES_PER_SOURCE=20
MAX_AI_CALLS_PER_RUN=30
DIGEST_ARTICLE_LIMIT=100
VOZ_MAX_THREAD_PAGES=15
FORUM_MAX_COMMENTS=70
FORUM_RAW_CONTENT_MAX_LENGTH=80000
REDDIT_COMMENT_LIMIT=30
REDDIT_COMMENT_DEPTH=3

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_PROXY_URL=

# Browser host proxy. Use http://host.docker.internal:8788/fetch when the app runs in Docker.
# Use http://127.0.0.1:8788/fetch when the server runs directly on the host.
BROWSER_PROXY_URL=
# Backward-compatible alias for VOZ/browser proxy.
VOZ_PROXY_URL=
# Extra article hosts allowed through the host browser proxy, comma-separated.
BROWSER_PROXY_ALLOWED_HOSTS=
