{
  "name": "newstamhv",
  "private": true,
  "workspaces": ["server", "client"],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "local:build": "npm run build && node scripts/local-build.mjs",
    "local:prod": "npm run local:build && npm run local:start",
    "local:start": "node --env-file=.env.local server/dist/index.js",
    "local:check-hosts": "node scripts/check-local-hosts.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
