# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://newstamhv:newstamhv@localhost:5432/newstamhv

# Admin token
ADMIN_TOKEN=dev-admin-token-change-this

# Scraper settings
SCRAPE_INTERVAL_HOURS=1
MAX_ARTICLES_PER_SOURCE=20
MAX_AI_CALLS_PER_RUN=30
DIGEST_ARTICLE_LIMIT=100
VOZ_MAX_THREAD_PAGES=4
FORUM_MAX_COMMENTS=40
FORUM_RAW_CONTENT_MAX_LENGTH=60000
REDDIT_COMMENT_LIMIT=30
REDDIT_COMMENT_DEPTH=3

# Reddit OAuth (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Reddit Proxy (optional)
REDDIT_PROXY_URL=

# Browser host proxy. Use http://127.0.0.1:8788/fetch when running this server directly on the host.
BROWSER_PROXY_URL=
# Backward-compatible alias for VOZ/browser proxy.
VOZ_PROXY_URL=
# Extra article hosts allowed through the host browser proxy, comma-separated.
BROWSER_PROXY_ALLOWED_HOSTS=

# Scrapling sidecar (anti-bot fetching service)
# In Docker: http://scrapling:8000 | Local: http://localhost:8000
SCRAPLING_SERVICE_URL=
SCRAPLING_TIMEOUT_MS=60000

# Blocked domains (comma-separated, skip fetch for these domains)
# Overrides the built-in default list if set
BLOCKED_DOMAINS=


# CORS (for local dev, typically the Vite dev server)
CORS_ORIGIN=http://localhost:5173
